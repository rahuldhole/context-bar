{
  "name": "context-bar",
  "displayName": "Context Bar",
  "description": "Trigger VS Code shortcuts and commands directly from your editor title bar",
  "version": "0.1.0",
  "publisher": "rahuldhole",
  "icon": "assets/icon.png",
  "author": {
    "name": "Rahul Dhole"
  },
  "license": "MIT",
  "keywords": [
    "context",
    "bar",
    "shortcuts",
    "editor",
    "title",
    "navigation",
    "commands",
    "productivity"
  ],
  "homepage": "https://github.com/rahuldhole/context-bar#readme",
  "bugs": {
    "url": "https://github.com/rahuldhole/context-bar/issues"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "package": "npx vsce package",
    "publish": "npx vsce publish"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rahuldhole/context-bar.git"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Context Bar",
      "properties": {
        "context-bar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Global toggle to enable or disable the Context Bar buttons."
        },
        "tabTools.actions": {
          "type": "array",
          "markdownDescription": "Map VS Code commands and shortcuts to buttons in the editor title bar.",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "command": { "type": "string" },
              "icon": { "type": "string" },
              "exts": { "type": "string" },
              "enabled": { "type": "boolean", "default": true },
              "priority": { "type": "number", "default": 0 }
            }
          }
        }
      }
    },
    "commands": [
      { "command": "context-bar.configure", "title": "Context Bar: Configure Shortcuts", "category": "Context Bar" },
      { "command": "context-bar.debugState", "title": "Context Bar: Debug Info", "category": "Context Bar" },
      
      { "command": "context-bar.slot.play.1", "title": "Trigger", "icon": "$(play)" },
      { "command": "context-bar.slot.play.2", "title": "Trigger", "icon": "$(play)" },
      { "command": "context-bar.slot.debug-start.1", "title": "Trigger", "icon": "$(debug-start)" },
      { "command": "context-bar.slot.eye.1", "title": "Trigger", "icon": "$(eye)" },
      { "command": "context-bar.slot.eye.2", "title": "Trigger", "icon": "$(eye)" },
      { "command": "context-bar.slot.checklist.1", "title": "Trigger", "icon": "$(checklist)" },
      { "command": "context-bar.slot.sync.1", "title": "Trigger", "icon": "$(sync)" },
      { "command": "context-bar.slot.trash.1", "title": "Trigger", "icon": "$(trash)" },
      { "command": "context-bar.slot.save.1", "title": "Trigger", "icon": "$(save)" },
      { "command": "context-bar.slot.book.1", "title": "Trigger", "icon": "$(book)" },
      { "command": "context-bar.slot.bug.1", "title": "Trigger", "icon": "$(bug)" },
      { "command": "context-bar.slot.zap.1", "title": "Trigger", "icon": "$(zap)" },
      { "command": "context-bar.slot.gear.1", "title": "Trigger", "icon": "$(gear)" },
      { "command": "context-bar.slot.search.1", "title": "Trigger", "icon": "$(search)" },
      { "command": "context-bar.slot.refresh.1", "title": "Trigger", "icon": "$(refresh)" },
      { "command": "context-bar.slot.edit.1", "title": "Trigger", "icon": "$(edit)" },
      { "command": "context-bar.slot.list-unordered.1", "title": "Trigger", "icon": "$(list-unordered)" },
      { "command": "context-bar.slot.symbol-method.1", "title": "Trigger", "icon": "$(symbol-method)" },
      { "command": "context-bar.slot.symbol-class.1", "title": "Trigger", "icon": "$(symbol-class)" },
      { "command": "context-bar.slot.new-file.1", "title": "Trigger", "icon": "$(new-file)" },
      { "command": "context-bar.slot.new-folder.1", "title": "Trigger", "icon": "$(new-folder)" },
      { "command": "context-bar.slot.diff.1", "title": "Trigger", "icon": "$(diff)" },
      { "command": "context-bar.slot.git-commit.1", "title": "Trigger", "icon": "$(git-commit)" },
      { "command": "context-bar.slot.terminal.1", "title": "Trigger", "icon": "$(terminal)" },
      { "command": "context-bar.slot.graph.1", "title": "Trigger", "icon": "$(graph)" },
      { "command": "context-bar.slot.database.1", "title": "Trigger", "icon": "$(database)" },
      { "command": "context-bar.slot.cloud.1", "title": "Trigger", "icon": "$(cloud)" },
      { "command": "context-bar.slot.lock.1", "title": "Trigger", "icon": "$(lock)" },
      { "command": "context-bar.slot.unlock.1", "title": "Trigger", "icon": "$(unlock)" },
      { "command": "context-bar.slot.home.1", "title": "Trigger", "icon": "$(home)" },
      { "command": "context-bar.slot.mail.1", "title": "Trigger", "icon": "$(mail)" },
      { "command": "context-bar.slot.bell.1", "title": "Trigger", "icon": "$(bell)" }
    ],
    "menus": {
      "editor/title": [
        { "command": "context-bar.slot.play.1", "when": "context-bar.slot.play.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.play.2", "when": "context-bar.slot.play.2.visible", "group": "navigation" },
        { "command": "context-bar.slot.debug-start.1", "when": "context-bar.slot.debug-start.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.eye.1", "when": "context-bar.slot.eye.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.eye.2", "when": "context-bar.slot.eye.2.visible", "group": "navigation" },
        { "command": "context-bar.slot.checklist.1", "when": "context-bar.slot.checklist.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.sync.1", "when": "context-bar.slot.sync.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.trash.1", "when": "context-bar.slot.trash.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.save.1", "when": "context-bar.slot.save.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.book.1", "when": "context-bar.slot.book.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.bug.1", "when": "context-bar.slot.bug.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.zap.1", "when": "context-bar.slot.zap.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.gear.1", "when": "context-bar.slot.gear.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.search.1", "when": "context-bar.slot.search.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.refresh.1", "when": "context-bar.slot.refresh.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.edit.1", "when": "context-bar.slot.edit.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.list-unordered.1", "when": "context-bar.slot.list-unordered.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.symbol-method.1", "when": "context-bar.slot.symbol-method.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.symbol-class.1", "when": "context-bar.slot.symbol-class.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.new-file.1", "when": "context-bar.slot.new-file.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.new-folder.1", "when": "context-bar.slot.new-folder.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.diff.1", "when": "context-bar.slot.diff.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.git-commit.1", "when": "context-bar.slot.git-commit.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.terminal.1", "when": "context-bar.slot.terminal.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.graph.1", "when": "context-bar.slot.graph.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.database.1", "when": "context-bar.slot.database.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.cloud.1", "when": "context-bar.slot.cloud.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.lock.1", "when": "context-bar.slot.lock.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.unlock.1", "when": "context-bar.slot.unlock.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.home.1", "when": "context-bar.slot.home.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.mail.1", "when": "context-bar.slot.mail.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.bell.1", "when": "context-bar.slot.bell.1.visible", "group": "navigation" }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.75.0",
    "typescript": "^4.9.5"
  }
}
