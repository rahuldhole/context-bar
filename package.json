{
  "name": "context-bar",
  "displayName": "Context Bar",
  "description": "Context-aware, user-configurable action buttons in the editor title area",
  "version": "0.1.0",
  "publisher": "rahuldhole",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "vscode:prepublish": "npm run compile"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Context Bar",
      "properties": {
        "tabTools.actions": {
          "type": "array",
          "description": "Custom actions to show in the editor title bar",
          "default": [
            {
              "id": "markdown.preview",
              "title": "Preview",
              "command": "markdown.showPreviewToSide",
              "icon": "preview",
              "when": "editorLangId == 'markdown'"
            },
            {
              "id": "json.format",
              "title": "Format",
              "command": "editor.action.formatDocument",
              "icon": "format",
              "when": "editorLangId == 'json'"
            }
          ],
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "command": { "type": "string" },
              "icon": { "type": "string", "enum": ["preview", "format", "play", "debug", "test", "sync", "trash", "save", "book", "bug", "zap", "gear"] },
              "when": { "type": "string" },
              "priority": { "type": "number" }
            }
          }
        }
      }
    },
    "commands": [
      { "command": "context-bar.slot.preview.1", "title": "Preview", "icon": "$(eye)" },
      { "command": "context-bar.slot.preview.2", "title": "Preview", "icon": "$(eye)" },
      { "command": "context-bar.slot.format.1", "title": "Format", "icon": "$(checklist)" },
      { "command": "context-bar.slot.format.2", "title": "Format", "icon": "$(checklist)" },
      { "command": "context-bar.slot.play.1", "title": "Run", "icon": "$(play)" },
      { "command": "context-bar.slot.play.2", "title": "Run", "icon": "$(play)" },
      { "command": "context-bar.slot.debug.1", "title": "Debug", "icon": "$(debug-start)" },
      { "command": "context-bar.slot.debug.2", "title": "Debug", "icon": "$(debug-start)" },
      { "command": "context-bar.slot.test.1", "title": "Test", "icon": "$(beaker)" },
      { "command": "context-bar.slot.test.2", "title": "Test", "icon": "$(beaker)" },
      { "command": "context-bar.slot.sync.1", "title": "Sync", "icon": "$(sync)" },
      { "command": "context-bar.slot.trash.1", "title": "Delete", "icon": "$(trash)" },
      { "command": "context-bar.slot.save.1", "title": "Save", "icon": "$(save)" },
      { "command": "context-bar.slot.book.1", "title": "Docs", "icon": "$(book)" },
      { "command": "context-bar.slot.bug.1", "title": "Issues", "icon": "$(bug)" },
      { "command": "context-bar.slot.zap.1", "title": "Flash", "icon": "$(zap)" },
      { "command": "context-bar.slot.gear.1", "title": "Settings", "icon": "$(gear)" }
    ],
    "menus": {
      "editor/title": [
        { "command": "context-bar.slot.preview.1", "when": "context-bar.slot.preview.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.preview.2", "when": "context-bar.slot.preview.2.visible", "group": "navigation" },
        { "command": "context-bar.slot.format.1", "when": "context-bar.slot.format.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.format.2", "when": "context-bar.slot.format.2.visible", "group": "navigation" },
        { "command": "context-bar.slot.play.1", "when": "context-bar.slot.play.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.play.2", "when": "context-bar.slot.play.2.visible", "group": "navigation" },
        { "command": "context-bar.slot.debug.1", "when": "context-bar.slot.debug.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.debug.2", "when": "context-bar.slot.debug.2.visible", "group": "navigation" },
        { "command": "context-bar.slot.test.1", "when": "context-bar.slot.test.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.test.2", "when": "context-bar.slot.test.2.visible", "group": "navigation" },
        { "command": "context-bar.slot.sync.1", "when": "context-bar.slot.sync.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.trash.1", "when": "context-bar.slot.trash.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.save.1", "when": "context-bar.slot.save.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.book.1", "when": "context-bar.slot.book.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.bug.1", "when": "context-bar.slot.bug.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.zap.1", "when": "context-bar.slot.zap.1.visible", "group": "navigation" },
        { "command": "context-bar.slot.gear.1", "when": "context-bar.slot.gear.1.visible", "group": "navigation" }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.75.0",
    "typescript": "^4.9.5"
  }
}
